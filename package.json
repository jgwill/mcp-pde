{
  "name": "iaip-mcp-pde",
  "version": "2.0.1",
  "description": "Prompt Decomposition Engine as MCP Server - LLM-driven decomposition into structured JSON with Four Directions mapping, ambiguity detection, and .pde/ storage",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mcp-pde": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "mcp",
    "prompt-decomposition",
    "llm",
    "ai-agents",
    "indigenous-ai",
    "medicine-wheel",
    "ceremonial-technology"
  ],
  "author": "Guillaume Descoteaux-Isabelle <jgi@jgwill.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jgwill/mcp-pde.git"
  },
  "bugs": {
    "url": "https://github.com/jgwill/mcp-pde/issues"
  },
  "homepage": "https://github.com/jgwill/mcp-pde#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "minimist": "^1.2.8",
    "uuid": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/minimist": "^1.2.5",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "rispecs",
    "scenarios"
  ]
}
